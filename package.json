{
  "name": "places",
  "private": true,
  "description": "Decentraland places",
  "version": "0.0.0-development",
  "author": "",
  "engines": {
    "node": "18.*",
    "npm": "8.* || 9.*"
  },
  "dependencies": {
    "@dcl/schemas": "^25.0.0",
    "@well-known-components/pushable-channel": "^1.0.3",
    "abort-controller": "^3.0.0",
    "aws-sdk": "^2.1002.0",
    "decentraland-gatsby": "^8.1.0",
    "express-fileupload": "^1.2.1",
    "html-escaper": "^3.0.3",
    "node-pg-migrate": "^6.0.0",
    "pg": "^8.13.1",
    "uuid": "^8.3.2",
    "web-push": "^3.4.5"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^1.0.6",
    "@types/express": "^4.17.3",
    "@types/express-fileupload": "^1.1.7",
    "@types/html-escaper": "^3.0.0",
    "@types/jest": "^29.5.1",
    "@types/line-reader": "^0.0.34",
    "@types/node": "^18.19.64",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.7.5",
    "@types/web-push": "^3.3.2",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "dotenv": "^8.6.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-babel-module": "^5.3.1",
    "eslint-import-resolver-jest": "^3.0.2",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-autofix": "^1.1.0",
    "eslint-plugin-css-import-order": "^1.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^4.0.0",
    "http-proxy-middleware": "^2.0.6",
    "husky": "^7.0.4",
    "jest": "^29.5.0",
    "line-reader": "^0.4.0",
    "lint-staged": "12.3.8",
    "nodemon": "^2.0.15",
    "prettier": "^2.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@dcl/schemas": "^25.0.0"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p .",
    "start": "DOTENV_CONFIG_PATH=.env.development nodemon --watch src/entities --watch src/server.ts -e ts,json --exec 'ts-node -r dotenv/config' src/server",
    "format": "prettier --write '**/*.{ts,js,json,md,yml,yaml}'",
    "lint": "eslint --ext .ts,.js ./src",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "migrate": "./node_modules/.bin/node-pg-migrate --envPath ./.env.development --tsconfig ./tsconfig.json -j ts -m ./src/migrations -d CONNECTION_STRING",
    "husky-setup": "husky install",
    "precommit": "lint-staged --config .husky/pre-commit.js",
    "update:roads": "ts-node bin/roads.ts",
    "update:places": "ts-node bin/placeMigrations.ts",
    "send:snapshot-to-files": "ts-node bin/snapshotToFiles.ts",
    "send:files-to-sqs": "DOTENV_CONFIG_PATH=.env.development ts-node -r dotenv/config bin/filesToSqs.ts",
    "send:snapshot-to-sqs": "npm run send:snapshot-to-files && npm run send:files-to-sqs",
    "test:sqs-message": "DOTENV_CONFIG_PATH=.env.development ts-node -r dotenv/config bin/testSqsMessage.ts",
    "rebuild:worlds:dev": "DOTENV_CONFIG_PATH=.env.development ts-node -r dotenv/config bin/rebuildWorldPlaces.ts",
    "rebuild:worlds:prd": "DOTENV_CONFIG_PATH=.env.production ts-node -r dotenv/config bin/rebuildWorldPlaces.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/decentraland/places"
  },
  "bugs": {
    "url": "https://github.com/decentraland/places/issues"
  }
}
